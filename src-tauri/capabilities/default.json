{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri-plugin-localhost/v2/schemas/schema.json",
  "identifier": "default",
  "description": "MyTools default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-set-title",
    "window-state:default",
    "opener:default",
    "notification:default",
    "dialog:default",
    "fs:allow-write-text-file",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**" }
      ]
    }
  ]
}

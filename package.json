{
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "prepare-dist": "node -e \"const{cpSync,copyFileSync,mkdirSync}=require('fs');mkdirSync('dist',{recursive:true});['js','pages','vendor'].forEach(d=>cpSync(d,'dist/'+d,{recursive:true}));cpSync('css','dist/css',{recursive:true,filter:s=>!s.endsWith('.less')});['index.html','favicon.svg'].forEach(f=>copyFileSync(f,'dist/'+f));\"",
    "less:build": "npx lessc css/core/tokens.less css/core/tokens.css && npx lessc css/core/ui.less css/core/ui.css"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "less": "^4.5.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-router": "^1.168.18",
    "dexie": "^4.4.2",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "shiki": "^4.0.2",
    "tailwindcss": "^4.2.2",
    "zustand": "^5.0.12"
  }
}
